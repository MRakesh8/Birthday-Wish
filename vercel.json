{
  "version": 2,
  "buildCommand": "pnpm install && pnpm --filter @workspace/maha-birthday run build",
  "outputDirectory": "dist",
  "installCommand": "npm install -g pnpm@latest",
  "framework": null,
  "rewrites": [
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "env": {
    "BASE_PATH": "/",
    "NODE_ENV": "production"
  }
}
